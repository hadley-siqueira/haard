class Pair:
    x : int
    y : int
    k : int[3]

class Node<T>:
    value : T
    next  : T*
    prev  : T*


class Coordinate(Pair):
    z : int

    def to_str : str
        "($x, $y, $z)"


    def init : void
        x = 0
        y = 0
        z = 0


class SuperNode<T>(Node<T>):
    def init : void
        next = 0
        prev = 0
