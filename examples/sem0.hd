import std.io.file

class Pixel:
    r : u8
    g : u8
    b : u8
    a : int

    def set_white : void
        r = 255

    def set_black : void
        r = 0

class Pair<T, K>:
    first  : T
    second : K

    def set_first : void
        @a : int

        a = 0

class Pixel:
    r : u8
    g : u8
    b : u8

def sum : int
    @a : int
    @b : int

    return a + b
