def power : i32
    @a : i32
    @b : i32

    return a ** b ** b

def bitwise_or : i32
    @a : i32
    @b : i32

    return a | b

def bitwise_xor : i32
    @a : i32
    @b : i32

    return a ^ b

def bitwise_and : i32
    @a : i32
    @b : i32

    return a & b

def sll : i32
    @a : i32
    @b : i32

    return a << b

def srl : i32
    @a : i32
    @b : i32

    return a >>> b

def sra : i32
    @a : i32
    @b : i32

    return a >> b >> c

def logical_not : i32
    return not 0 and !0

def address_of : i32
    v = 0x12
    v = 0x12
    v = 0x12
    return &v

def dereference : i32
    v = &a
    p = *v
    p = **v
    p = * * v
    return ***p

def bitwise_not : i32
    v = ~0 & ~1
    return ~v

def unary_plus_minus : i32
    a = -0
    b = -1
    c = +0 + -1
    return +a + -b - -c

def unaries : void
    a = 0
    ++a
    --a
    this.a = 0
    a = null

    v = (1, 2, 3)
    v = (1; 2; 3)
    return
