def power : i32
    @a : i32
    @b : i32

    return a ** b ** b

def bitwise_or : i32
    @a : i32
    @b : i32

    return a | b

def bitwise_xor : i32
    @a : i32
    @b : i32

    return a ^ b

def bitwise_and : i32
    @a : i32
    @b : i32

    return a & b

def sll : i32
    @a : i32
    @b : i32

    return a << b

def srl : i32
    @a : i32
    @b : i32

    return a >>> b

def sra : i32
    @a : i32
    @b : i32

    return a >> b >> c

def logical_not : i32
    return not 0 and !0

def address_of : i32
    v = 0x12
    return &v

