def main : void
    a = |a, b| {
        return a + b
    }
    a = |a : i32, b : i32| {
        return a + b
    }
    a = |a : i32, b : i32| -> i32 {
        return a + b
    }
    a = |a, b| {
        if a > b:
            return a + b
    }
    a = |a : i32, b : i32| {
        while true:
            if a > b:
                return a + b
        return 0
    }
    a = |a : i32, b : i32| -> i32 {
        return a + b
    }
